# FarmersHub — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/farmershub
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/farmershub
MONGO_URI=mongodb://localhost:27017/farmershub

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_strong_secret_key
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
